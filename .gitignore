# =========================
# 기존 설정 (완벽함!)
# =========================
node_modules/
build/
dist/
coverage/
.DS_Store
*.log
# env 파일은 보안상 민감한 정보가 담길 수 있으므로 기본적으로 무시하지만, 
# 예시 파일은 포함하여 팀원들이 참고할 수 있도록 설정
.env*
!.env.example

# 1. 에디터 설정 (팀원 간 화면/테마 충돌 방지)
.vscode/
.idea/

# 2. 운영체제 찌꺼기 파일 (윈도우, 맥 혼용 시 방어)
Thumbs.db
desktop.ini

# 3. TypeScript 캐시 파일 (빌드 속도를 위해 임시 생성되는 파일)
*.tsbuildinfo

# 4. ESLint / Prettier 캐시 (코드 포맷팅 찌꺼기)
.eslintcache
.prettiercache

# 5. Vite 관련 임시 폴더
.vite/

# 6. pnpm 오류 로그 (에러 났을 때 생기는 로그 파일)
pnpm-debug.log*